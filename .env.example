# Frontend (Vite expone solo las variables VITE_*)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...  # Settings → API Keys → Publishable key (pública)
VITE_BACKEND_URL=http://localhost:3000             # URL del backend Mastra en local

# Backend
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...                 # Settings → API Keys → Secret key (privada, nunca al frontend)
DATABASE_URL=postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres
