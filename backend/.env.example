SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SECRET_KEY=<service-role-key>
ANTHROPIC_API_KEY=<anthropic-api-key>
FRONTEND_ORIGIN=https://<tu-app>.vercel.app  # Origen del frontend para CORS (producción). En local se omite.
ENABLE_OBSERVABILITY=true  # Solo local: activa trazas del agente en Mastra Studio. NO definir en Mastra Cloud (evita gasto e impide la hibernación).
